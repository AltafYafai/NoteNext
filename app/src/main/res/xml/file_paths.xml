<?xml version="1.0" encoding="utf-8"?>
<resources>
    <paths>
        <!-- Camera photos stored via getExternalFilesDir(DIRECTORY_PICTURES) -->
        <external-files-path name="camera_images" path="Pictures" />

        <!-- Fallback: camera photos stored in cacheDir/pictures -->
        <cache-path name="camera_cache_images" path="pictures" />

        <!-- Logcat sharing -->
        <cache-path name="logs" path="logs" />
    </paths>
</resources>